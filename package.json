{
  "name": "@xstr-me/api-spec",
  "version": "0.0.1-alpha",
  "type": "module",
  "description": "OpenAPI specification for XStr.me services with TypeScript support",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./spec": "./api-spec.yml",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/",
    "api-spec.yml",
    "README.md",
    "LICENSE",
    "types/"
  ],
  "scripts": {
    "build": "npm run clean && npm run compile && npm run bundle",
    "clean": "rimraf dist/ coverage/ .nyc_output/",
    "compile": "tsc",
    "bundle": "rollup -c",
    "dev": "rollup -c -w",
    "validate": "redocly lint api-spec.yml",
    "generate-docs": "redoc-cli build api-spec.yml --output docs/index.html",
    "lint": "spectral lint api-spec.yml",
    "lint:ts": "eslint src/**/*.ts types/**/*.ts --fix",    "format": "prettier --write \"src/**/*.{ts,js,json}\" \"types/**/*.{ts,js,json}\" \"*.{js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json}\" \"types/**/*.{ts,js,json}\" \"*.{js,json,md}\"",
    "lint-staged": "lint-staged",
    "test": "npm run validate && npm run lint && npm run test:unit",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "prepare": "husky install",
    "prepublishOnly": "npm run build && npm test",
    "prepack": "npm run build",
    "publish-maven": "mvn clean deploy",
    "docs:dev": "typedoc src/typescript/index.ts --out docs/api --watch",
    "docs:build": "typedoc src/typescript/index.ts --out docs/api"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xstr-me/api-spec.git"
  },
  "keywords": [
    "openapi",
    "api",
    "specification",
    "xstr",
    "swagger",
    "rest",
    "typescript",
    "javascript",
    "nodejs",
    "browser",
    "api-client",
    "schema"
  ],
  "author": "XStr.me Team",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/xstr-me/api-spec/issues"
  },
  "homepage": "https://github.com/xstr-me/api-spec#readme",
  "devDependencies": {
    "@apidevtools/swagger-cli": "^4.0.4",
    "@redocly/cli": "^1.34.3",
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^12.0.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.0.6",
    "@semantic-release/npm": "^12.0.1",
    "@semantic-release/release-notes-generator": "^13.0.0",
    "@stoplight/spectral-cli": "^6.11.0",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "audit-ci": "^7.0.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-extended": "^5.0.3",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "publint": "^0.2.8",
    "redoc-cli": "^0.13.21",
    "rimraf": "^5.0.7",
    "rollup": "^4.17.2",
    "rollup-plugin-dts": "^6.1.1",
    "semantic-release": "^23.1.1",
    "ts-jest": "^29.1.2",
    "tslib": "^2.6.2",
    "typedoc": "^0.25.13",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
